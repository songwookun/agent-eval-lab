# ── 실제 키는 이 파일을 복사해서 `.env` 로 만들고 채운다 (.env 는 git 에 안 올라감) ──

# Gemini API (메인 LLM) — https://aistudio.google.com/apikey (무료 free tier)
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# Langfuse (트레이싱 백엔드) — A안: W1 은 콘솔 exporter 라 미사용.
# W1 이후 Langfuse 셀프호스트 붙일 때 주석 해제.
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
