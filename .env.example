# ── 실제 키는 이 파일을 복사해서 `.env` 로 만들고 채운다 (.env 는 git 에 안 올라감) ──

# Gemini API (메인 LLM) — https://aistudio.google.com/apikey (무료 free tier)
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# Groq API (멀티 프로바이더 어댑터 — 무료 티어, 분당 30요청) — https://console.groq.com
GROQ_API_KEY=your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Langfuse 셀프호스트 (docker-compose) — 관측 백엔드.
# 이 3개가 다 있으면 otel_setup 이 OTLP exporter 를 켜서 Langfuse 로 trace 전송.
# 없으면 콘솔 exporter 만 동작(graceful).
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_SECRET_KEY=sk-lf-your-key

# compose 자동 부트스트랩 — web UI 가입 없이 프로젝트/유저/키 자동 생성.
# PUBLIC/SECRET_KEY 는 위 LANGFUSE_PUBLIC/SECRET_KEY 와 같은 값으로.
LANGFUSE_INIT_ORG_ID=aelab-org
LANGFUSE_INIT_PROJECT_ID=aelab-proj
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-your-key
LANGFUSE_INIT_USER_EMAIL=you@example.com
LANGFUSE_INIT_USER_PASSWORD=changeme1234

# compose 보안 시크릿 — 로컬은 아무 랜덤. 외부 노출 시 openssl rand -hex 32 로 교체.
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
SALT=generate-random
NEXTAUTH_SECRET=generate-random
